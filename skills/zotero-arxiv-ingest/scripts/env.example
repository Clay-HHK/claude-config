# Zotero API credentials
# Get from https://www.zotero.org/settings/keys
# 1. Top of page shows "Your userID" -> ZOTERO_LIBRARY_ID
# 2. Click "Create new private key" -> tick library access + notes access + write access
# 3. Copy the one-time-shown key -> ZOTERO_API_KEY
ZOTERO_LIBRARY_ID=
ZOTERO_API_KEY=
ZOTERO_LIBRARY_TYPE=user
